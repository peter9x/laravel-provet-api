{
    "name": "peter9x/laravel-provet-api",
    "description": "Laravel package for Provet API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Peter",
            "email": "pedro.teixeira@mupy.io"
        }
    ],
    "homepage": "https://github.com/peter9x/laravel-provet-api",
    "keywords": [
        "Laravel"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "league/oauth2-client": "^2",
        "guzzlehttp/guzzle": "7.x",
        "ext-json": "*",
        "ext-fileinfo": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "pestphp/pest": "^v2.34|^3.7",
        "phpunit/phpunit": "^11.5",
        "orchestra/testbench": "^10.4|^11.0",
        "laravel/pint": "^1.24",
        "spatie/laravel-health": "^1.40"
    },
    "suggest": {
        "spatie/laravel-health": "Allows monitoring Business Central connections via the Mupy\\BusinessCentral\\HealthChecks\\BusinessCentralCheck health check (spatie/laravel-health)."
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform": {
            "php": "8.2"
        }
    },
    "autoload": {
        "psr-4": {
            "Mupy\\ProvetApi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mupy\\ProvetApi\\ProvetServiceProvider"
            ],
            "aliases": {
                "ProvetApi": "Mupy\\ProvetApi\\Facades\\Provet"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
